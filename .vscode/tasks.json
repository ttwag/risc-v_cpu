{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile check current file",
      "type": "shell",
      "command": "bash ./scripts/compile_src_sv.sh \"${file}\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "run testbench sim",
      "type": "shell",
      "command": "bash ./scripts/run_tb_sv.sh \"${file}\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}